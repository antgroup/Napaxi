# Large prebuilt native runtime assets are stored via Git LFS.
# See packages/flutter/android/jniLibs/THIRD-PARTY.md for provenance and
# THIRD-PARTY-LICENSES.md for the licenses governing these binaries.
#
# Note: packages/flutter/android/jniLibs/*/libnapaxi_api_bridge.so is a
# first-party build artifact; it is .gitignore'd and never committed.

# Android sandbox rootfs image.
packages/flutter/android/assets/alpine-rootfs.bin filter=lfs diff=lfs merge=lfs -text

# iOS iSH sandbox rootfs archive.
packages/ios/Sources/Napaxi/Resources/alpine-rootfs.tar.gz filter=lfs diff=lfs merge=lfs -text

# Third-party prebuilt sandbox runtime libraries (PRoot, talloc, musl loader).
packages/flutter/android/assets/libtalloc.so.2 filter=lfs diff=lfs merge=lfs -text
packages/flutter/android/jniLibs/arm64-v8a/libproot.so filter=lfs diff=lfs merge=lfs -text
packages/flutter/android/jniLibs/arm64-v8a/libldmusl.so filter=lfs diff=lfs merge=lfs -text
packages/flutter/android/jniLibs/arm64-v8a/libloader.so filter=lfs diff=lfs merge=lfs -text
