<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Napaxi</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Napaxi</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>agent.host.callback</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>agent-host</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>Napaxi uses calendar access only when you ask an agent to inspect or manage calendar events.</string>
	<key>NSCalendarsUsageDescription</key>
	<string>Napaxi uses calendar access only when you ask an agent to inspect or manage calendar events.</string>
	<key>NSCalendarsWriteOnlyAccessUsageDescription</key>
	<string>Napaxi uses calendar write access only when you ask an agent to create calendar events.</string>
	<key>NSCameraUsageDescription</key>
	<string>Napaxi uses the camera only when you choose to attach media or scan a Local A2A pairing code.</string>
	<key>NSContactsUsageDescription</key>
	<string>Napaxi uses contacts only when you ask an agent to work with contact information.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>Napaxi uses your location only when you ask an agent for location-aware help, including tasks that may need to continue while the app is in the background.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Napaxi uses your location only when you ask an agent for location-aware help.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Napaxi uses the microphone only when you choose to record audio.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Napaxi uses the local network only when you enable Local A2A to connect nearby agents.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_napaxi-a2a._tcp</string>
	</array>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Napaxi saves media to your photo library only when you choose to export it.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Napaxi uses your photo library only when you choose media to attach.</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>UIWindowSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>UIWindowScene</string>
					<key>UISceneConfigurationName</key>
					<string>flutter</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).SceneDelegate</string>
					<key>UISceneStoryboardFile</key>
					<string>Main</string>
				</dict>
			</array>
		</dict>
	</dict>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
